@model IEnumerable<Projektverwaltung.Models.Project>

@{
    ViewData["Title"] = "Index";
}

<h1>Projects</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProjectName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedOn)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.ProjectName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @item.CreatedOn.ToString("dd.MM.yyyy")
                </td>
                <td>
                    <div class="d-flex gap-2">

                        <a asp-action="Edit" class="btn btn-warning" asp-route-id="@item.ProjectId">Edit</a>
                        <a asp-action="Details" class="btn btn-info" asp-route-id="@item.ProjectId">Details</a>
                        <a asp-action="Delete" class="btn btn-danger" asp-route-id="@item.ProjectId">Delete</a>
                        <a asp-controller="ProjectTask"
                               asp-action="Index"
                               asp-route-projectId="@item.ProjectId"
                               class="btn btn-secondary">
                               Tasks
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
