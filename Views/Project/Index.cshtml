@model IEnumerable<Projektverwaltung.Models.Project>

@{
    ViewData["Title"] = "Index";
}

<h1>Projects</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Project</a>
</p>


<form method="get" form asp-action="Index" class="mb-3" style="max-width:420px;">
   
    <div class="input-group">

        <input name="searchTerm" value="@ViewBag.FilterProject" class="form-control" placeholder="Filter by projects" />

    </div>


        <select name="status" class="form-select" value="@ViewBag.Status">

            <option value="" disabled hidden selected="@(ViewBag.Status == null)">Filter by project status</option>

         
            <option value="" selected="@(ViewBag.Status != null && ViewBag.Status.ToString() == "")">All</option>
            <option value="Planned" selected="@(ViewBag.Status?.ToString() == "Planned")">Planned</option>
            <option value="Active" selected="@(ViewBag.Status?.ToString() == "Active")">Active</option>
            <option value="Completed" selected="@(ViewBag.Status?.ToString() == "Completed")">Completed</option>

        </select>

        <button type="submit" class="btn btn-outline-secondary">
            Filter
        </button>
    @if (ViewBag.FilterProject != null)
    {
        <div class="alert alert-info">
            Gefiltert nach: <strong>@ViewBag.FilterProject</strong>

            <a asp-action="Index" class="ms-2">Remove filter</a>
        </div>
    }
</form>



<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProjectName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CurrentStatus)
            </th>
            <th class="text-nowrap">
                @Html.DisplayNameFor(model => model.CreatedOn)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.ProjectName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CurrentStatus)
                </td>
                <td>
                    @item.CreatedOn.ToString("dd.MM.yyyy")
                </td>
                <td>
                    <div class="d-flex gap-2">

                        <a asp-action="Edit" class="btn btn-warning" asp-route-id="@item.ProjectId">Edit</a>
                        <a asp-action="Details" class="btn btn-info" asp-route-id="@item.ProjectId">Details</a>
                        <a asp-action="Delete" class="btn btn-danger" asp-route-id="@item.ProjectId">Delete</a>
                        <a asp-controller="ProjectTask"
                           asp-action="Index"
                           asp-route-projectId="@item.ProjectId"
                           class="btn btn-secondary">
                            Tasks
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
