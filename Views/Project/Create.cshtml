@using static Projektverwaltung.Models.Project
@model Projektverwaltung.Models.Project

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Project</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProjectName" class="control-label"></label>
                <input id="titleInput" asp-for="ProjectName" class="form-control" />
                <span asp-validation-for="ProjectName" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <textarea id="descriptionInput"
                          asp-for="Description"
                          class="form-control"
                          rows="5">
                </textarea>
            </div>
            <button type="button"
                    id="generateBtn"
                    class="btn btn-dark mt-2">

                Generate with AI

            </button>
            <div class="form-group">
                <label asp-for="CurrentStatus" class="control-label"></label>
                <select asp-for="CurrentStatus" class="form-control" asp-items="Html.GetEnumSelectList<Status>()"></select>
                <span asp-validation-for="CurrentStatus" class="text-danger"></span>
            </div>
            <div class="mt-2">
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-success btn-sm" />
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mt-2">
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("generateBtn").addEventListener("click", async function () {
            const title = document.getElementById("titleInput").value;

           
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch('@Url.Action("GenerateDescription", "Project")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `title=${encodeURIComponent(title)}`
                });

                if (!response.ok) {
                    throw new Error(`Server error: ${response.status}`);
                }

                const data = await response.json();

              
                document.getElementById("descriptionInput").value = data.description;

            } catch (error) {
               
                console.error("AI Generation Error:", error);
                alert("Could not generate description. Please check the console for details.");
            }
        });
    </script>
}



