
@{
    ViewData["Title"] = "Index";
}

<div class="container mt-5">
    <div class="row align-items-center">

        <div class="col-md-6">
            <h1 class="display-4 fw-bold">
                Manage your projects efficiently
            </h1>

            <p class="lead mt-3">
                Organize projects, track tasks and monitor progress with a clean ASP.NET MVC application.
            </p>

            @if (User.Identity.IsAuthenticated)
            {
            <div class="mt-4">
                <a asp-controller="Project"
                       asp-action="Index"
                       class="btn btn-primary btn-lg">
                    View Projects
                </a>
            </div>
            }
            else
            {
                <div class="mt-4">
                    <a asp-controller="Auth"
                           asp-action="Login"
                           class="btn btn-primary btn-lg">
                        Login
                    </a>
                </div>
            }
        </div>

        <div class="col-md-6 text-center">
            <img src="~/images/project-management.svg"
                 class="img-fluid"
                 style="max-height:400px;" />
        </div>

    </div>
</div>

